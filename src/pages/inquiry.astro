---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Request a Quote">
  <div class="container" style="max-width: 600px; padding: 5rem 0;">
    <h2 style="text-align: center;">Get a Professional Quote</h2>
    <p style="text-align: center; color: #666;">Tell us your project requirements and we will reply within 24 hours.</p>
    
    <form action="https://formspree.io/f/你的FormspreeID" method="POST" style="margin-top: 2rem; display: flex; flex-direction: column; gap: 15px;">
      <input type="text" name="product" id="prodName" placeholder="Product Name" style="padding: 12px; border: 1px solid #ddd; border-radius: 4px;" readonly />
      <input type="text" name="name" placeholder="Your Name" required style="padding: 12px; border: 1px solid #ddd; border-radius: 4px;" />
      <input type="email" name="email" placeholder="Your Business Email" required style="padding: 12px; border: 1px solid #ddd; border-radius: 4px;" />
      <textarea name="message" rows="5" placeholder="Quantity, Dimensions, or Project Details..." required style="padding: 12px; border: 1px solid #ddd; border-radius: 4px;"></textarea>
      <button type="submit" class="btn" style="border: none; cursor: pointer; font-size: 1rem;">Send My Inquiry</button>
    </form>
  </div>

  <script>
    const urlParams = new URLSearchParams(window.location.search);
    const prod = urlParams.get('product');
    if (prod) document.getElementById('prodName').value = prod;
  </script>
</Layout>
