---
import Layout from '../layouts/Layout.astro';

// 使用 try...catch 避免因为没有产品文件而导致网站构建崩溃
let products = [];
try {
  products = await Astro.glob('../content/products/*.md');
} catch (err) {
  console.warn('No product files found. Please add products via Decap CMS.');
}
---

<Layout title="Home">
  <!-- 1. 轮播图模块：修改为固定比例 -->
  <section class="slider-container">
    <div class="slider">
      <div class="slide" style="background-image: url('/images/slide1.jpg');"></div>
      <div class="slide" style="background-image: url('/images/slide2.jpg');"></div>
      <div class="slide" style="background-image: url('/images/slide3.jpg');"></div>
    </div>
  </section>

  <!-- 2. 产品展示网格 (核心修改区) -->
  <section id="products" style="padding: 4rem 0;">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: 3rem;">Our Collections</h2>
      <div class="product-grid">
        {products.map((product) => {
          const slug = product.file.split('/').pop().split('.')[0];
          const p = product.frontmatter;

          return (
            <div class="product-card">
              <a href={`/products/${slug}`} class="product-link">
                {p.image ? (
                  <img src={p.image} alt={p.title} class="product-img" />
                ) : (
                  <div class="img-placeholder">[Image: {p.title}]</div>
                )}
                <div style="padding: 1.5rem; padding-bottom: 0.5rem;">
                  <h3 class="product-title">{p.title}</h3>
                  <p style="color: #666; margin-top: 5px;">Color: {p.color}</p>
                </div>
              </a>
              <div style="padding: 0 1.5rem 1.5rem 1.5rem;">
                <a href={`/inquiry?product=${p.title}`} class="btn-sm">Request Quote</a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 3. 公司信息板块 -->
  <section style="background: #1a1a1a; color: white; padding: 5rem 0;">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px;">
        <div>
          <h2 style="color: #d4a373;">Suzhou Vigor New Materials</h2>
          <p style="color: #ccc; line-height: 1.8;">
            No.5, Changsheng Road, Zhitang Town, Changshu City, China.<br/>
            We are dedicated to providing high-quality acoustic solutions for global projects.
          </p>
        </div>
        <div class="contact-links">
          <h3>Quick Contact</h3>
          <ul>
            <li>📧 Email: <a href="mailto:info@csvigor.com">info@csvigor.com</a></li>
            <li>📞 Tel: <a href="tel:0512-52828160">0512-52828160</a></li>
            <li>📱 Mobile: <a href="tel:+8613812831131">+8613812831131</a></li>
            <li>🌐 Website: <a href="https://www.csvigor.com" target="_blank">www.csvigor.com</a></li>
            <li>🏢 Alibaba: <a href="https://szfet.m.en.alibaba.com/?spm=a2700.details.0.0.290514a9OiEON9&wx_navbar_transparent=true&wx_screen_direc=portrait&productId=1601873678937&from=detail_company_card" target="_blank" style="color: #ff6600;">Visit Our Store</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* --- 轮播图尺寸适配调整 --- */
    .slider-container { 
      width: 100%; 
      aspect-ratio: 3 / 1; /* 强制容器比例为 750:250，即 3:1 */
      overflow: hidden; 
      position: relative; 
      background: #333; 
    }
    .slider { width: 100%; height: 100%; position: relative; }

    .slide { 
      width: 100%; height: 100%; 
      position: absolute; top: 0; left: 0;
      /* 使用 contain 确保 750x250 的图片完整显示在 3:1 的容器内，不被裁切 */
      background-size: contain; 
      background-position: center; 
      background-repeat: no-repeat;
      opacity: 0; 
      animation: fadeCarousel 15s infinite; 
    }

    .slide:nth-child(1) { animation-delay: 0s; }
    .slide:nth-child(2) { animation-delay: 5s; }
    .slide:nth-child(3) { animation-delay: 10s; }

    @keyframes fadeCarousel {
      0% { opacity: 0; z-index: 1; }
      10% { opacity: 1; z-index: 2; }
      33% { opacity: 1; z-index: 2; }
      43% { opacity: 0; z-index: 1; }
      100% { opacity: 0; z-index: 1; }
    }

    /* --- 产品网格样式 --- */
    .product-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
    @media (max-width: 992px) { .product-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 576px) { .product-grid { grid-template-columns: 1fr; } }
    .product-card { border: 1px solid #eee; border-radius: 8px; overflow: hidden; background: #fff; transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .product-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.08); }
    .product-link { text-decoration: none; color: inherit; display: block; }
    .product-img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; display: block; border-bottom: 1px solid #f5f5f5; }
    .product-title { font-size: 1.25rem; margin: 0; transition: color 0.2s; }
    .product-link:hover .product-title { color: #d4a373; }
    .img-placeholder { height: 250px; background: #f9f9f9; display: flex; align-items: center; justify-content: center; color: #999; }
    .contact-links ul { list-style: none; padding: 0; margin: 0; }
    .contact-links li { margin-bottom: 15px; font-size: 1.1rem; }
    .contact-links a { color: #fff; text-decoration: none; border-bottom: 1px solid transparent; transition: 0.3s; }
    .contact-links a:hover { color: #d4a373; border-bottom-color: #d4a373; }
    .btn-sm { background: #d4a373; color: white; padding: 10px 16px; text-decoration: none; border-radius: 4px; display: block; text-align: center; font-weight: bold; transition: background 0.3s; }
    .btn-sm:hover { background: #c08e5c; }
  </style>
</Layout>
