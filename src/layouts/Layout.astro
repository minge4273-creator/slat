---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Vigor Acoustic Panels</title>
    <style is:global>
      body { font-family: 'Helvetica Neue', Arial, sans-serif; margin: 0; color: #333; line-height: 1.6; }
      nav { background: #fff; color: #333; padding: 1rem 5%; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; }
      nav a { color: #333; text-decoration: none; margin-left: 20px; font-weight: 500; }
      .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
      footer { background: #f9f9f9; padding: 4rem 0; border-top: 1px solid #eee; }
      .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; }
      .footer-links a { display: block; color: #666; text-decoration: none; margin-bottom: 10px; }
    </style>
  </head>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
  <body>
    <nav>
      <div style="font-size: 1.4rem; font-weight: bold; color: #d4a373;">VIGOR NEW MATERIALS</div>
      <div>
        <a href="/">Home</a>
        <a href="/inquiry">Get a Quote</a>
      </div>
    </nav>
    <slot />
    <footer>
      <div class="container">
        <div class="footer-grid">
          <div>
            <h4 style="color: #d4a373;">About Us</h4>
            <p style="font-size: 0.9rem; color: #888;">Professional manufacturer of wood slat acoustic panels for wall and ceiling treatments.</p>
          </div>
          <div class="footer-links">
            <h4>Quick Links</h4>
            <a href="https://www.csvigor.com">Main Website</a>
            <a href="https://szfet.m.en.alibaba.com">Alibaba Store</a>
          </div>
          <div>
            <h4>Contact Info</h4>
            <p style="font-size: 0.9rem; color: #888;">
              📞 +86-512-52828160<br/>
              📧 info@csvigor.com<br/>
              📍 Changshu, China
            </p>
          </div>
        </div>
        <hr style="border: 0; border-top: 1px solid #ddd; margin: 2rem 0;"/>
        <p style="text-align: center; font-size: 0.8rem; color: #aaa;">&copy; 2026 Suzhou Vigor New Materials Co., Ltd. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
